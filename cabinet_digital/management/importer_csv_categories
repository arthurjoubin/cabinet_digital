import csv
import sqlite3
from django.utils.text import slugify
from datetime import datetime
import markdown

# Connexion à la base de données SQLite
conn = sqlite3.connect('db.sqlite3')
cursor = conn.cursor()

# Initialiser les compteurs
created_count = 0
updated_count = 0

# Ouvrir le fichier CSV
with open('cabinet_digital/management/Liste des categories.csv', 'r', encoding='utf-8') as f:
    csv_reader = csv.reader(f, quotechar='"', delimiter=',', quoting=csv.QUOTE_ALL, skipinitialspace=True)

    # Ignorer l'en-tête si nécessaire
    next(csv_reader, None)
    
    # Insérer ou mettre à jour les données
    for row in csv_reader:
        content_html = markdown.markdown(row[4])
        name = row[0]
        slug = slugify(row[1])[:49] 
        print(slug) # Utiliser le SEO:Slug fourni

        # Vérifier si l'entrée existe déjà
        cursor.execute('SELECT id FROM cabinet_digital_softwarecategory WHERE slug = ?', (slug,))
        existing_entry = cursor.fetchone()
        
        if existing_entry:
            # Mettre à jour l'entrée existante
            cursor.execute('''
                UPDATE cabinet_digital_softwarecategory 
                SET name = ?, description = ?
                WHERE slug = ?
            ''', (
                name,
                content_html,
                slug
            ))
            updated_count += 1
        else:
            # Insérer une nouvelle entrée
            cursor.execute('''
                INSERT INTO cabinet_digital_softwarecategory 
                (name, slug, description) 
                VALUES (?, ?, ?)
            ''', (
                name,
                slug,
                content_html,
            ))
            created_count += 1

# Valider les changements et fermer la connexion
conn.commit()
conn.close()

print(f"Importation et mise à jour des catégories terminées.")
print(f"Catégories créées : {created_count}")
print(f"Catégories mises à jour : {updated_count}")