
import csv
import sqlite3

# Connexion à la base de données SQLite
conn = sqlite3.connect('db.sqlite3')
cursor = conn.cursor()

# Ouvrir le fichier CSV
with open(r'C:\Users\arthu\OneDrive\Bureau\cabinet_digital\media\import_histo\Liste des logiciels-Export (7).csv', 'r', encoding='utf-8') as f:
    csv_reader = csv.reader(f, quotechar='"', delimiter=',', quoting=csv.QUOTE_ALL, skipinitialspace=True)
    
    # Ignorer l'en-tête si nécessaire
    next(csv_reader, None)
    # Insérer les données
    for row in csv_reader:
        # Correspondance directe entre les colonnes CSV et les champs de la table
        cursor.execute('''
            INSERT INTO cabinet_digital_software 
            (name, description, editeur, site, video, slug) 
            VALUES (?, ?, ?, ?, ?, ?)
        ''', (
            row[0],  # name
            row[1],  # description
            row[2],  # editeur
            row[4],  # site
            row[5],  # video
            row[6]   # slug
        ))

# Valider les changements et fermer la connexion
conn.commit()
conn.close()

print("Importation terminée.")