import csv
import sqlite3
from django.utils.text import slugify
from datetime import datetime
import markdown

# Connexion à la base de données SQLite
conn = sqlite3.connect('db.sqlite3')
cursor = conn.cursor()

# Initialiser les compteurs
created_count = 0
updated_count = 0

# Ouvrir le fichier CSV
with open('cabinet_digital/management/Liste des logiciels.csv', 'r', encoding='utf-8') as f:
    csv_reader = csv.reader(f, quotechar='"', delimiter=',', quoting=csv.QUOTE_ALL, skipinitialspace=True)

    # Lire les en-têtes
    headers = next(csv_reader)
    
    # Insérer ou mettre à jour les données
    for row in csv_reader:
        name = row[0].strip()  # Solution
        slug = slugify(row[5])[:49]  # SEO:Slug
        description = row[3].strip()  # Description
        description_html = markdown.markdown(description)
        site = row[1].strip()  # Site
        video = row[9].strip()  # URL Vidéo
        excerpt = row[13].strip()  # Preview 1 phrase
        is_top_pick = False
        is_published = row[18] == "true"
        unique_views = 0
        print(is_published)

        # Vérifier si l'entrée existe déjà
        cursor.execute('SELECT id FROM cabinet_digital_software WHERE slug = ?', (slug,))
        existing_entry = cursor.fetchone()
        
        if existing_entry:
            # Mettre à jour l'entrée existante
            cursor.execute('''
                UPDATE cabinet_digital_software 
                SET name = ?, description = ?,  site = ?, video = ?, excerpt = ?, is_published = ?
                WHERE slug = ?
            ''', (name, description_html, site, video, excerpt,is_published, slug))
            updated_count += 1
        else:
            # Insérer une nouvelle entrée
            cursor.execute('''
                INSERT INTO cabinet_digital_software 
                (name, description, site, video, slug, excerpt, is_published, is_top_pick, unique_views) 
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
            ''', (name, description_html, site, video, slug, excerpt, is_published, is_top_pick, unique_views))
            created_count += 1

# Valider les changements et fermer la connexion
conn.commit()
conn.close()

print(f"Importation et mise à jour des logiciels terminées.")
print(f"Logiciels créés : {created_count}")
print(f"Logiciels mis à jour : {updated_count}")